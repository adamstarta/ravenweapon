{% sw_extends '@Storefront/storefront/page/account/order/index.html.twig' %}

{% block page_checkout_confirm_header %}
    {% set isTwintDeclined = page.errorCode is not null and 'TWINT' in page.errorCode|upper %}
    {% set isPaymentCanceled = page.errorCode == 'CHECKOUT__CUSTOMER_CANCELED_EXTERNAL_PAYMENT' %}
    {% set isPaymentExpired = page.errorCode == 'CHECKOUT__PAYMENT_TOKEN_EXPIRED' %}

    {% if isTwintDeclined %}
        <div style="background: linear-gradient(135deg, #1e1b2e 0%, #2d1f3d 100%); border: 1px solid rgba(239, 68, 68, 0.3); border-radius: 12px; padding: 32px; margin-bottom: 24px; text-align: center;">
            <div style="width: 64px; height: 64px; margin: 0 auto 16px; background: rgba(239, 68, 68, 0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="15" y1="9" x2="9" y2="15"/>
                    <line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
            </div>
            <h2 style="color: #f5f5f5; font-family: 'Chakra Petch', sans-serif; font-size: 22px; font-weight: 700; margin-bottom: 12px;">
                TWINT-Zahlung abgebrochen
            </h2>
            <p style="color: #9ca3af; font-size: 15px; line-height: 1.6; max-width: 500px; margin: 0 auto 24px;">
                Ihre TWINT-Transaktion wurde abgebrochen oder ist abgelaufen. Die Bestellung wurde storniert und es wurde kein Betrag belastet.
            </p>
            <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
                <a href="{{ path('frontend.account.order.page') }}" style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: rgba(255,255,255,0.08); color: #f5f5f5; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 600; border: 1px solid rgba(255,255,255,0.12); transition: all 0.2s;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Meine Bestellungen
                </a>
                <a href="{{ path('frontend.home.page') }}" style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: linear-gradient(135deg, #FDE047, #F59E0B); color: #111827; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 700; transition: all 0.2s;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="9" cy="21" r="1"/>
                        <circle cx="20" cy="21" r="1"/>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                    </svg>
                    Weiter einkaufen
                </a>
            </div>
        </div>
    {% elseif isPaymentCanceled %}
        {% sw_include '@Storefront/storefront/utilities/alert.html.twig' with {
            type: 'danger',
            content: 'account.externalPaymentCanceled'|trans|sw_sanitize
        } %}
        <h1 class="confirm-main-header">
            {{ 'account.completePayment'|trans|sw_sanitize }}
        </h1>
    {% elseif isPaymentExpired %}
        {% sw_include '@Storefront/storefront/utilities/alert.html.twig' with {
            type: 'danger',
            content: 'account.externalPaymentExpired'|trans|sw_sanitize
        } %}
        <h1 class="confirm-main-header">
            {{ 'account.completePayment'|trans|sw_sanitize }}
        </h1>
    {% elseif page.errorCode is not null %}
        {% sw_include '@Storefront/storefront/utilities/alert.html.twig' with {
            type: 'danger',
            content: 'account.externalPaymentFailure'|trans|sw_sanitize
        } %}
        <h1 class="confirm-main-header">
            {{ 'account.completePayment'|trans|sw_sanitize }}
        </h1>
    {% else %}
        <h1 class="confirm-main-header">
            {{ 'account.completePayment'|trans|sw_sanitize }}
        </h1>
    {% endif %}
{% endblock %}

{# Hide the payment form when TWINT is declined - order is already cancelled #}
{% block page_checkout_aside_actions %}
    {% set isTwintDeclined = page.errorCode is not null and 'TWINT' in page.errorCode|upper %}
    {% if not isTwintDeclined %}
        {{ parent() }}
    {% endif %}
{% endblock %}
